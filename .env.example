# =============================================================================
# PlatformDeployment — Environment Variables
# Copy this file to .env and fill in values for your environment.
# Never commit .env to version control.
# =============================================================================

# ── SwitchBoard ──────────────────────────────────────────────────────────────
# Port that the SwitchBoard gateway listens on.
PORT_SWITCHBOARD=20401

# ── Status API ───────────────────────────────────────────────────────────────
# Port for the stack-level status / health aggregation endpoint.
PORT_STATUS=20400

# ── Plane (optional) ─────────────────────────────────────────────────────────
# Set to "true" to have up.sh start Plane automatically.
# Plane is a task board used by OperationsCenter. It is not required for
# SwitchBoard to operate. See scripts/plane.sh for manual lifecycle control.
# PLANE_ENABLED=false
# PLANE_URL=http://localhost:8080

# ── Plane database credentials (optional overrides) ──────────────────────────
# Defaults match the docker-compose.yaml environment defaults.
# Only set these if you've changed the values in plane.env.
# POSTGRES_USER=plane
# POSTGRES_PASSWORD=plane
# POSTGRES_DB=plane

# ── Plane backup (optional) ──────────────────────────────────────────────────
# Override default backup destination (default: ~/sync/platform/backups/).
# PLATFORM_BACKUPS_DIR=/path/to/backups
# Number of pg_dump files to keep before rotating older ones.
# PLANE_BACKUP_KEEP=10

# ── Secrets sync (optional) ──────────────────────────────────────────────────
# Override default secrets sync directory (default: ~/sync/platform/config/).
# PLATFORM_SECRETS_DIR=/path/to/config

# ── OperationsCenter (optional) ──────────────────────────────────────────────
# Override default OperationsCenter checkout path for workers commands.
# OPERATIONS_CENTER_ROOT=/path/to/OperationsCenter

# ── Compose project ──────────────────────────────────────────────────────────
# Optional: override the default compose project name.
# COMPOSE_PROJECT_NAME=platformdeployment

# ── Logging ──────────────────────────────────────────────────────────────────
# Log level applied across services that honour it.
# LOG_LEVEL=info
